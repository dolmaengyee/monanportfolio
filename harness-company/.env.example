# ── Neon Postgres (선택) ──────────────────────────────────────────────────────
# 연락처 폼 저장 + 관리자 대시보드에 사용됩니다. 설정하지 않으면 사이트는
# 정상 동작하며, 연락처 폼은 "저장 설정 전" 상태로 안내됩니다.
#
# Vercel Marketplace Neon 연동 시 자동 주입됩니다.
# 로컬 개발: `vercel env pull .env.local` 로 값을 내려받으세요.
DATABASE_URL=

# ── 관리자 비밀번호 (서버 전용) ───────────────────────────────────────────────
# /admin/login 에서 사용하는 단일 비밀번호입니다. 브라우저에 노출되지 않습니다.
# Vercel → Settings → Environment Variables 에 ADMIN_PASSWORD 를 등록하세요.
ADMIN_PASSWORD=

# ── 사이트 기본 설정 ──────────────────────────────────────────────────────────
# 배포 후 실제 도메인으로 변경하세요 (예: https://mycompany.com)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── SEO: 구글 서치콘솔 ────────────────────────────────────────────────────────
# 1. https://search.google.com/search-console 접속
# 2. URL 접두어로 사이트 등록
# 3. '다른 확인 방법' > 'HTML 태그' 클릭
# 4. content="XXXX" 안의 값만 복사해서 아래에 붙여넣기
GOOGLE_SITE_VERIFICATION=

# ── SEO: 네이버 서치어드바이저 ──────────────────────────────────────────────
# 1. https://searchadvisor.naver.com 접속
# 2. 웹마스터 도구 > 사이트 등록
# 3. 'HTML 태그' 방식으로 인증
# 4. content="XXXX" 안의 값만 복사해서 아래에 붙여넣기
NAVER_SITE_VERIFICATION=

# ── 구글 애널리틱스 (선택) ────────────────────────────────────────────────────
# 1. https://analytics.google.com 에서 GA4 속성 생성
# 2. 측정 ID (G-XXXXXXXXXX 형식) 복사해서 아래에 붙여넣기
NEXT_PUBLIC_GA_ID=
