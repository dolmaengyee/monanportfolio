# ── Supabase (필수 - 결과 저장/공유/관리자) ──────────────────────────────────
# 1. https://supabase.com 에서 새 프로젝트 생성 (GitHub으로 로그인)
# 2. Project Settings > API > Project URL 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# 3. Project Settings > API > anon public 키 복사
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
#
# ── Supabase 테이블 생성 SQL ────────────────────────────────────────────────
# SQL Editor에서 아래 쿼리 실행:
#
# CREATE TABLE test_results (
#   id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
#   name TEXT NOT NULL,
#   phone TEXT,
#   final_type INTEGER NOT NULL CHECK (final_type BETWEEN 1 AND 9),
#   scores JSONB NOT NULL,
#   ranking JSONB NOT NULL,
#   answers JSONB NOT NULL,
#   created_at TIMESTAMPTZ DEFAULT now()
# );
# ALTER TABLE test_results ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "public_insert" ON test_results FOR INSERT WITH CHECK (true);
# CREATE POLICY "public_select" ON test_results FOR SELECT USING (true);

# ── 관리자 비밀번호 (필수) ───────────────────────────────────────────────────
# 관리자 페이지(/admin) 접속 비밀번호
# 영문+숫자 조합 8자 이상 권장. 절대 소스코드에 직접 입력하지 마세요.
NEXT_PUBLIC_ADMIN_PASSWORD=your-admin-password

# ── 사이트 기본 설정 ──────────────────────────────────────────────────────────
# 배포 후 실제 도메인으로 변경하세요
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── SEO: 구글 서치콘솔 ────────────────────────────────────────────────────────
# 1. https://search.google.com/search-console 접속
# 2. URL 접두어로 사이트 등록
# 3. '다른 확인 방법' > 'HTML 태그' 클릭
# 4. content="XXXX" 안의 값만 복사해서 아래에 붙여넣기
GOOGLE_SITE_VERIFICATION=

# ── SEO: 네이버 서치어드바이저 ──────────────────────────────────────────────
# 1. https://searchadvisor.naver.com 접속
# 2. 웹마스터 도구 > 사이트 등록
# 3. 'HTML 태그' 방식으로 인증
# 4. content="XXXX" 안의 값만 복사해서 아래에 붙여넣기
NAVER_SITE_VERIFICATION=

# ── 구글 애널리틱스 (선택) ────────────────────────────────────────────────────
# 1. https://analytics.google.com 에서 GA4 속성 생성
# 2. 측정 ID (G-XXXXXXXXXX 형식) 복사해서 아래에 붙여넣기
NEXT_PUBLIC_GA_ID=
