# ── Neon Postgres (선택 - 결과 저장/공유/관리자) ─────────────────────────────
# DB는 선택사항입니다. 이 값이 없어도 사이트는 정상 동작하며, 결과 저장/공유/
# 관리자 기능만 비활성화됩니다.
#
# Vercel Marketplace의 Neon 연동 시 이 변수는 자동 주입됩니다.
# 로컬 개발에서는 `vercel env pull .env.local` 로 값을 받아오세요.
# (서버 전용 변수 — NEXT_PUBLIC_ 접두사를 붙이지 마세요.)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
#
# ── 테이블 생성 SQL ─────────────────────────────────────────────────────────
# Neon SQL Editor에서 아래 쿼리를 한 번 실행하세요:
#
# CREATE TABLE IF NOT EXISTS test_results (
#   id           uuid PRIMARY KEY DEFAULT gen_random_uuid(),
#   name         text NOT NULL,
#   phone        text,
#   final_type   text NOT NULL,
#   scores       jsonb,
#   ranking      jsonb,
#   answers      jsonb,
#   consented_at timestamptz,
#   created_at   timestamptz DEFAULT now()
# );

# ── 관리자 비밀번호 (선택 - /admin 사용 시 필수) ─────────────────────────────
# 관리자 페이지(/admin) 접속 비밀번호. 서버 전용 변수입니다.
# 절대 NEXT_PUBLIC_ 접두사를 붙이지 마세요 (붙이면 클라이언트 번들에 노출됩니다).
# 영문+숫자 조합 8자 이상 권장. 로그인 성공 시 httpOnly 세션 쿠키가 발급됩니다.
ADMIN_PASSWORD=your-admin-password

# ── 사이트 기본 설정 ──────────────────────────────────────────────────────────
# 배포 후 실제 도메인으로 변경하세요
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── SEO: 구글 서치콘솔 ────────────────────────────────────────────────────────
# 1. https://search.google.com/search-console 접속
# 2. URL 접두어로 사이트 등록
# 3. '다른 확인 방법' > 'HTML 태그' 클릭
# 4. content="XXXX" 안의 값만 복사해서 아래에 붙여넣기
GOOGLE_SITE_VERIFICATION=

# ── SEO: 네이버 서치어드바이저 ──────────────────────────────────────────────
# 1. https://searchadvisor.naver.com 접속
# 2. 웹마스터 도구 > 사이트 등록
# 3. 'HTML 태그' 방식으로 인증
# 4. content="XXXX" 안의 값만 복사해서 아래에 붙여넣기
NAVER_SITE_VERIFICATION=

# ── 구글 애널리틱스 (선택) ────────────────────────────────────────────────────
# 1. https://analytics.google.com 에서 GA4 속성 생성
# 2. 측정 ID (G-XXXXXXXXXX 형식) 복사해서 아래에 붙여넣기
NEXT_PUBLIC_GA_ID=
